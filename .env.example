# ============================================================
# WhatsApp AI Assistant — Environment Variables Example
# ============================================================

# ── Server ──────────────────────────────────────────────────
SERVER_PORT=8082

# ── AI Provider ─────────────────────────────────────────────
# Choose: "gemini" or "groq"
AI_PROVIDER=gemini

# Google Gemini API Keys (comma-separated for key rotation/fallback)
GEMINI_API_KEYS=your_gemini_api_key_1,your_gemini_api_key_2
GEMINI_MODEL=gemini-2.5-flash

# Groq API Keys (comma-separated for key rotation/fallback)
GROQ_API_KEYS=your_groq_api_key_1,your_groq_api_key_2
GROQ_MODEL=llama-3.3-70b-versatile

# Max tokens per AI reply
AI_MAX_TOKENS=600

# ── Twilio WhatsApp ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Admin Dashboard Credentials ─────────────────────────────
ADMIN_EMAIL=admin@business.com
ADMIN_PASSWORD=admin123

# ── JWT Security ─────────────────────────────────────────────
JWT_SECRET=whatsapp-ai-assistant-super-secure-jwt-secret-key-min-32-chars
JWT_EXPIRATION_MS=86400000

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=*
