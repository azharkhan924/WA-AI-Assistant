# ============================================================
# WhatsApp AI Assistant — Environment Variables Example
# ============================================================

# ── Server ──────────────────────────────────────────────────
SERVER_PORT=8082

# ── AI Provider Configuration ───────────────────────────────
# Choose: "gemini" or "groq"
AI_PROVIDER=gemini

# Google Gemini API Keys (comma-separated for multi-key rotation)
GEMINI_API_KEYS=your_gemini_api_key_1,your_gemini_api_key_2
GEMINI_MODEL=gemini-2.5-flash

# Groq API Keys (comma-separated for multi-key rotation)
GROQ_API_KEYS=your_groq_api_key_1,your_groq_api_key_2
GROQ_MODEL=llama-3.3-70b-versatile

# Max tokens per AI reply
AI_MAX_TOKENS=600

# ── Admin Dashboard Credentials ─────────────────────────────
ADMIN_EMAIL=admin@business.com
ADMIN_PASSWORD=admin123

# ── JWT Security ─────────────────────────────────────────────
JWT_SECRET=whatsapp-ai-assistant-super-secure-jwt-secret-key-min-32-chars
JWT_EXPIRATION_MS=86400000

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=*
